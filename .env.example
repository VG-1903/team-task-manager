# Top-level reference for required environment variables.
# In local dev, these go in server/.env (copy server/.env.example).
# In Railway, set these as service variables.

PORT=4000
NODE_ENV=production

# Postgres connection string. Reference Railway's Postgres plugin variable:
#   DATABASE_URL=${{Postgres.DATABASE_URL}}
DATABASE_URL=

# JWT signing secret. Generate one with: openssl rand -hex 48
JWT_SECRET=
JWT_EXPIRES_IN=7d

# Comma-separated allowed origins, or "*" to allow all.
CORS_ORIGIN=*
